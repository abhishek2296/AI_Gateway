# PostgreSQL container
POSTGRES_DB=ai_coding_assistant
POSTGRES_USER=ai_app
POSTGRES_PASSWORD=replace-with-a-local-development-password
POSTGRES_PORT=5432

# FastAPI application (when run from your machine, outside Docker)
DATABASE_URL=postgresql+asyncpg://ai_app:replace-with-a-local-development-password@localhost:5432/ai_coding_assistant
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_ECHO=false
